# ──────────────────────────────────────────
# LeQuyDon — Docker Compose root environment variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# ── MySQL ────────────────────────────────
MYSQL_ROOT_PASSWORD=lqd_root
MYSQL_PASSWORD=lqd_dev

# ── Backend (.env in /backend/) ──────────
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=lqd
DB_PASSWORD=lqd_dev
DB_NAME=lqd

REDIS_HOST=redis
REDIS_PORT=6379

# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_48_CHARS
JWT_EXPIRATION=900
REFRESH_TOKEN_EXPIRATION=604800

# ── Cloudflare R2 Storage (optional — fallback to local uploads in dev) ──
# Account ID from Cloudflare dashboard → R2 overview
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Bucket name (canonical env used by backend config)
R2_BUCKET_NAME=lequydon-media
# Public URL (custom domain or r2.dev). Empty → service returns 7-day presigned URLs
R2_PUBLIC_URL=https://cdn.lequydon.edu.vn
# Legacy / optional aliases (not required — kept for reference)
# R2_BUCKET=lequydon-media
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Mail (optional)
RESEND_API_KEY=
ADMIN_EMAIL=admin@lequydon.edu.vn

# ISR Revalidation — Generate with: openssl rand -base64 32
REVALIDATE_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
NEXT_REVALIDATE_URL=http://frontend:3000

# ── Frontend (.env in /frontend/) ────────
NEXT_PUBLIC_API_URL=https://demo.remoteterminal.online/api
NEXT_PUBLIC_SITE_URL=https://demo.remoteterminal.online

# ── Dev Ports (tranh xung dot voi WebPhoto + VietNet) ─
# Frontend: 3200 (WebPhoto: 3000, VietNet: 3100)
# Backend:  4200 (WebPhoto: 4000, VietNet: 4100)
# MySQL:    3308 (WebPhoto: 3306, VietNet: 3307)
# Redis:    6381 (WebPhoto: 6379, VietNet: 6380)
# Nginx:    8080/8443

# ── Backup ───────────────────────────────
MYSQL_BACKUP_PASSWORD=lqd_dev

# ── Google Drive Backup (optional) ───────
# Service Account authentication — see scripts/.gdrive-credentials.example.json
GDRIVE_ENABLED=false
GDRIVE_CREDENTIALS_PATH=./scripts/.gdrive-credentials.json
GDRIVE_FOLDER_ID=
GDRIVE_DB_SUBFOLDER=database
GDRIVE_UPLOADS_SUBFOLDER=media
# Giu N ban moi nhat trong moi subfolder, xoa cu hon
GDRIVE_KEEP_COUNT=14
# Thu muc chua .sql.gz do backup-mysql.sh tao ra
BACKUP_DIR=/opt/lqd/backups
# Thu muc uploads cua backend (zip truoc khi upload)
UPLOADS_DIR=./backend/uploads
