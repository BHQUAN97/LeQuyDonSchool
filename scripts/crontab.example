# ──────────────────────────────────────────
# LeQuyDon — System crontab (/etc/cron.d/lqd)
# Install: sudo cp /opt/lqd/scripts/crontab.example /etc/cron.d/lqd
#          sudo chmod 644 /etc/cron.d/lqd
# Schedule offset: Backup 2:30 AM (VietNet=2:00) | Cleanup Sun 3:30 AM
# ──────────────────────────────────────────

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin

# MySQL backup — daily 2:30 AM (offset 30min từ VietNet 2:00 AM)
30 2 * * * root /opt/lqd/scripts/backup-mysql.sh >> /var/log/lqd/backup.log 2>&1

# Disk monitoring — every 30 minutes
*/30 * * * * root /opt/lqd/scripts/monitor-disk.sh >> /var/log/lqd/cron.log 2>&1

# Docker cleanup — weekly Sunday 3:30 AM (offset: VietNet=3:00, LeQuyDon=3:30)
30 3 * * 0 root /opt/lqd/scripts/docker-cleanup.sh >> /var/log/lqd/docker-cleanup.log 2>&1
