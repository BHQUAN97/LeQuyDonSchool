{
  "name": "lequydon-backend",
  "version": "0.1.0",
  "description": "Le Quy Don Primary School - Backend API",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "lint": "eslint 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/database/data-source.ts",
    "seed:admin": "ts-node -r tsconfig-paths/register src/database/seeds/admin-seed.ts",
    "seed:admin:prod": "node dist/database/seeds/admin-seed.js",
    "seed:content": "ts-node -r tsconfig-paths/register src/database/seeds/content-seed.ts",
    "seed:content:prod": "node dist/database/seeds/content-seed.js",
    "seed:admissions": "ts-node -r tsconfig-paths/register src/database/seeds/seed-admissions.ts",
    "seed:admissions:prod": "node dist/database/seeds/seed-admissions.js",
    "seed:pages": "ts-node -r tsconfig-paths/register src/database/seeds/pages-seed.ts",
    "seed:pages:prod": "node dist/database/seeds/pages-seed.js",
    "seed:pages-p1": "ts-node -r tsconfig-paths/register src/database/seeds/seed-pages-part1.ts",
    "seed:pages-p1:prod": "node dist/database/seeds/seed-pages-part1.js",
    "seed:pages-p2": "ts-node -r tsconfig-paths/register src/database/seeds/seed-pages-part2.ts",
    "seed:pages-p2:prod": "node dist/database/seeds/seed-pages-part2.js",
    "seed:pages-p3": "ts-node -r tsconfig-paths/register src/database/seeds/seed-pages-part3.ts",
    "seed:pages-p3:prod": "node dist/database/seeds/seed-pages-part3.js",
    "seed:categories-articles": "ts-node -r tsconfig-paths/register src/database/seeds/seed-categories-articles.ts",
    "seed:categories-articles:prod": "node dist/database/seeds/seed-categories-articles.js",
    "seed:events": "ts-node -r tsconfig-paths/register src/database/seeds/seed-events.ts",
    "seed:events:prod": "node dist/database/seeds/seed-events.js",
    "seed:contacts-settings-nav": "ts-node -r tsconfig-paths/register src/database/seeds/seed-contacts-settings-nav.ts",
    "seed:contacts-settings-nav:prod": "node dist/database/seeds/seed-contacts-settings-nav.js",
    "seed:media": "ts-node -r tsconfig-paths/register src/database/seeds/seed-media.ts",
    "seed:media:prod": "node dist/database/seeds/seed-media.js",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1027.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/typeorm": "^10.0.0",
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.1.0",
    "mysql2": "^3.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  }
}
