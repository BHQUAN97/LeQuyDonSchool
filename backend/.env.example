# Server
LQD_PORT=4200
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=lequydon
DB_PASSWORD=lequydon_dev
DB_NAME=lequydon

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-this-secret-in-production-min-32-chars
JWT_EXPIRATION=900
REFRESH_TOKEN_EXPIRATION=604800

# Admin Seed
ADMIN_EMAIL=admin@lequydon.edu.vn
ADMIN_PASSWORD=Admin@123456

# CORS — comma-separated. Chi bao gom origin MINH can.
# Dev: http://localhost:3200
# Prod: https://lqd.bhquan.store (KHONG kem localhost)
ALLOWED_ORIGINS=http://localhost:3200

# Cloudflare R2 Storage (optional — fallback to local uploads in dev)
# Endpoint derived as: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lequydon-media
# Public URL (custom domain or r2.dev). Empty → service returns 7-day presigned URLs
R2_PUBLIC_URL=https://cdn.lequydon.edu.vn
